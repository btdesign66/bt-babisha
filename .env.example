# Copy to .env and fill real values (do NOT commit .env)

# ---------- HDFC SmartGateway ----------
# Use production base URL for real client payments
# (config.json can also hold BASE_URL + MERCHANT_ID)
HDFC_SMARTGATEWAY_BASE_URL=https://smartgateway.hdfc.bank.in
HDFC_SMARTGATEWAY_MERCHANT_ID=YOUR_MERCHANT_ID
HDFC_SMARTGATEWAY_RESELLER_ID=hdfc_reseller

# Required: Basic auth for S2S APIs.
# Value should be base64(API_KEY + ':')
# You can paste either:
# - "Basic <base64>"  OR
# - "<base64>"
HDFC_SMARTGATEWAY_AUTH=Basic YOUR_BASE64_APIKEY_COLON

# Optional but recommended (enable "Use signed response" in dashboard)
HDFC_SMARTGATEWAY_RESPONSE_KEY=YOUR_RESPONSE_KEY

# Safety: keep this OFF in production
ALLOW_CONFIG_PAYMENT_SECRETS=0

# ---------- Supabase (optional for saving payment status) ----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PAYMENTS_TABLE=payment_orders

